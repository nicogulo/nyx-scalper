# ── Scalper V2 Config ─────────────────────────────────────────────────────
# Copy this file to .env.scalper and fill in your values.
# All values have defaults in scalper-v2.py — only override what you need.

# ── Mode ──────────────────────────────────────────────────────────────────
export SCALPER_MODE=testnet                # testnet | live
export SCALPER_DRY_RUN=false               # true = detect signals only, no execution

# ── API Keys ─────────────────────────────────────────────────────────────
export BINANCE_API_KEY=
export BINANCE_SECRET_KEY=
export BINANCE_TESTNET_API_KEY=
export BINANCE_TESTNET_SECRET_KEY=

# ── Trading Parameters ───────────────────────────────────────────────────
export SCALPER_PAIRS=BTCUSDT,ETHUSDT,SOLUSDT,XRPUSDT,DOGEUSDT,BNBUSDT,SUIUSDT,XAGUSDT,ZECUSDT,CLUSDT
export SCALPER_LEVERAGE=20
export SCALPER_SIZE_PCT=0.20               # 20% of available balance per trade
export SCALPER_MAX_TRADES_DAY=10
export SCALPER_MAX_GLOBAL_POSITIONS=1    # max 1 concurrent open position

# ── TP/SL ─────────────────────────────────────────────────────────────────
export SCALPER_TP_PCT=0.010                # 1.0% take profit
export SCALPER_SL_PCT=0.005                # 0.5% stop loss

# ── Risk Management ──────────────────────────────────────────────────────
export SCALPER_DAILY_LOSS_LIMIT_PCT=0.03   # -3% circuit breaker
export SCALPER_TRAILING_ACTIVATE=0.003     # 0.3% profit to activate trailing
export SCALPER_TRAILING_DISTANCE=0.002     # 0.2% trailing distance

# ── Fees ─────────────────────────────────────────────────────────────────
export SCALPER_TAKER_FEE=0.0005            # 0.05% taker fee
export SCALPER_MIN_NET_TP_PCT=0.03        # 3% min net TP after fees
export SCALPER_MIN_BALANCE=10             # skip trading below this balance (USDT)
